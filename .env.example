# ================================================
# Nexa - AI Voice Assistant Configuration
# ================================================
# Copy this file to .env and fill in your API keys

# ========== REQUIRED: Choose One AI Service ==========

# Option 1: OpenAI API (Recommended for GPT-4 quality)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Option 2: Google Gemini API (Free option)
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key-here

# ========== Optional: AI Service Selection ==========
# Choose which AI service to use: 'openai' or 'gemini'
# Default is 'openai' if both are configured
AI_SERVICE=openai

# ========== Server Configuration ==========
# Server port (default: 3000)
PORT=3000

# Node environment
NODE_ENV=development

# ========== Database (if using external DB in future) ==========
# DATABASE_URL=mongodb://localhost/student-app
# DB_HOST=localhost
# DB_PORT=27017

# ========== Optional: Feature Flags ==========
# Enable/disable certain features
ENABLE_VOICE_RECOGNITION=true
ENABLE_VOICE_SYNTHESIS=true
ENABLE_TASK_AWARENESS=true
